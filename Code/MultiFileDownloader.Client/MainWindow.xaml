<Window x:Class="MultiFileDownloader.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multi File Downloader - Pro Version" Height="600" Width="1000"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <!-- GRID CHÍNH CHIA 2 CỘT -->
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/> <!-- Cột trái -->
            <ColumnDefinition Width="*"/>   <!-- Cột phải -->
        </Grid.ColumnDefinitions>

        <!-- ================= DANH SÁCH FILE SERVER ================= -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}" 
                CornerRadius="12" Margin="0,0,10,0" Padding="15">

            <DockPanel>

                <!-- Tiêu đề -->
                <TextBlock Text="Files on Server"
                           DockPanel.Dock="Top"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- List file từ server -->
                <ListBox x:Name="lstServerFiles"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextBrush}"
                         FontSize="14"
                         PreviewMouseMove="lstServerFiles_PreviewMouseMove">

                    <!-- Style item -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="Margin" Value="0,2"/>
                        </Style>
                    </ListBox.ItemContainerStyle>

                </ListBox>
            </DockPanel>
        </Border>

        <!-- ================= DOWNLOAD QUEUE ================= -->
        <Border Grid.Column="1" Background="{StaticResource SecondaryBrush}" 
                CornerRadius="12" Margin="10,0,0,0" Padding="15">

            <DockPanel>

                <!-- Tiêu đề -->
                <TextBlock Text="Download Queue"
                           DockPanel.Dock="Top"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>

                <!-- Hướng dẫn -->
                <TextBlock Text="Drag and drop files here to start"
                           DockPanel.Dock="Top"
                           Foreground="{StaticResource SubTextBrush}"
                           FontSize="12"
                           Margin="0,0,0,15"/>

                <!-- Vùng drop -->
                <Grid AllowDrop="True"
                      Drop="Grid_Drop"
                      Background="Transparent">

        <!-- LIST DOWNLOAD -->
    <ListView x:Name="lstDownloads"
                        ItemsSource="{Binding Downloads}"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalContentAlignment="Stretch">

                    <!-- 🔥 THÊM ĐOẠN NÀY NGAY ĐÂY -->
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#252525" CornerRadius="8" Margin="0,5" Padding="15">

                        <!-- 🔥 DÁN GRID MỚI VÀO ĐÂY -->
                        <Grid Margin="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding FileName}"
                                    Grid.Row="0" Grid.Column="0"
                                    Foreground="White"
                                    FontWeight="SemiBold"/>

                            <TextBlock Text="{Binding Speed, StringFormat={}{0:F0} KB/s}"
                                    Grid.Row="0" Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Foreground="DodgerBlue"/>

                            <Button Grid.Row="0"
                                    Grid.Column="2"
                                    Grid.RowSpan="3"
                                    Content="{Binding PauseText}"
                                    Command="{Binding TogglePauseCommand}"
                                    Width="80"
                                    Height="35"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="Orange"
                                    Foreground="White"/>

                            <ProgressBar Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Value="{Binding Progress}"
                                        Height="6"
                                        Margin="0,10,0,10"/>

                            <TextBlock Text="{Binding Status}"
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Foreground="Gray"/>

                            <TextBlock Text="{Binding Progress, StringFormat={}{0}%}"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    Foreground="White"/>
                        </Grid>

                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

</ListView>
                </Grid>          <!-- đóng Grid (drop area) -->
            </DockPanel>         <!-- đóng DockPanel -->
        </Border>                <!-- đóng border phải -->
    </Grid>                      <!-- đóng grid chính -->
</Window>                        <!-- đóng window -->
