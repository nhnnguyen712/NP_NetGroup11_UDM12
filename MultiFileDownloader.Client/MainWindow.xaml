<Window x:Class="MultiFileDownloader.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Multi File Downloader" Height="500" Width="800">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT: SERVER FILE LIST ===== -->
        <GroupBox Header="Files on Server" Grid.Column="0" Margin="5">
            <ListBox x:Name="lstServerFiles"
                     PreviewMouseMove="lstServerFiles_PreviewMouseMove"/>
        </GroupBox>

        <!-- ===== RIGHT: DOWNLOAD AREA ===== -->
        <GroupBox Header="Download Queue (Drag &amp; Drop here)" Grid.Column="1" Margin="5">
            <Grid AllowDrop="True"
                  Drop="Grid_Drop">

                <ListView x:Name="lstDownloads">
                    <ListView.View>
                        <GridView>

                            <!-- File name -->
                            <GridViewColumn Header="File" Width="150"
                                            DisplayMemberBinding="{Binding FileName}"/>

                            <!-- Progress -->
                            <GridViewColumn Header="Progress" Width="150">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ProgressBar Value="{Binding Progress}"
                                                     Maximum="100"
                                                     Height="20"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Speed -->
                            <GridViewColumn Header="Speed (KB/s)" Width="100"
                                            DisplayMemberBinding="{Binding Speed}"/>

                            <!-- Status -->
                            <GridViewColumn Header="Status" Width="100"
                                            DisplayMemberBinding="{Binding Status}"/>

                        </GridView>
                    </ListView.View>
                </ListView>

            </Grid>
        </GroupBox>

    </Grid>
</Window>